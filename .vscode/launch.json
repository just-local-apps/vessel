{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Vessel",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "vessel.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8090",
        "--reload"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "python": "${workspaceFolder}/.venv/bin/python",
      "justMyCode": false,
      "console": "integratedTerminal"
    }
  ]
}
