# ----- Required -----
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Your personal token. Vessel hashes this to derive a user_id. Multi-user:
# anyone with their own >=16-char token gets their own isolated state.
# Treat as a password. Lose it → lose access to that user's data.
VESSEL_AUTH_TOKEN=change-me-to-a-long-random-string

# Server-side master key — encrypts every user's state, event payloads, and
# invocation prompts/responses at rest. Generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Losing this key = losing every user's data. Rotate carefully.
VESSEL_ENCRYPTION_KEY=

# ----- LLM provider -----
# Pick "groq" (default — cheap, fast, openai/gpt-oss-120b on Groq Cloud)
# or "anthropic" to fall back to Claude. Each provider's keys/models live
# in their own env vars below so both can coexist.
LLM_PROVIDER=groq

# Groq (OpenAI-compatible API) — default.
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# Anthropic / Claude — fallback. Used when LLM_PROVIDER=anthropic.
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-opus-4-7

# ----- Phoenix Cloud tracing (optional) -----
# When PHOENIX_API_KEY + PHOENIX_COLLECTOR_ENDPOINT are set, every LLM call
# is auto-traced via OpenInference and shipped to Phoenix Cloud. The
# endpoint is shown on the Phoenix Cloud "Settings → API Keys" page and
# typically looks like https://app.phoenix.arize.com/s/<workspace>.
# Leave empty to disable tracing.
PHOENIX_API_KEY=
PHOENIX_COLLECTOR_ENDPOINT=
PHOENIX_PROJECT=vessel

# ----- Runtime -----
HOST=0.0.0.0
PORT=8080
TIMEZONE=America/Los_Angeles
WAKE_HOUR=6
BEDTIME_HOUR=21
WORKDAY_START_HOUR=9
WORKDAY_END_HOUR=17
